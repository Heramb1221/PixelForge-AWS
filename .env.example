# Copy this file to .env and fill in real values.
# NEVER commit the actual .env file.

# --- Flask ---
FLASK_ENV=production
FLASK_SECRET_KEY=replace-with-a-long-random-string

# --- AWS ---
AWS_REGION=ap-south-1
S3_ORIGINALS_BUCKET=pixelforge-originals-changeme
S3_PROCESSED_BUCKET=pixelforge-processed-changeme
PRESIGNED_URL_EXPIRY_SECONDS=300

# --- Database (Amazon RDS PostgreSQL) ---
DB_HOST=replace-with-your-rds-endpoint.ap-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=pixelforge
DB_USER=pixelforge_app
DB_PASSWORD=replace-with-a-strong-password
DB_SSLMODE=require
DB_POOL_MIN_CONN=1
DB_POOL_MAX_CONN=5

# --- Internal API (shared secret used by both Lambdas to call back into Flask) ---
INTERNAL_API_KEY=replace-with-a-long-random-string

# --- Upload constraints ---
MAX_UPLOAD_SIZE_BYTES=15728640
ORPHAN_MAX_AGE_HOURS=24
